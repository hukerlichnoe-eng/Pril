    <div class="card">
        <h3>📑 Электронный Журнал ТУ-3</h3>        <div class="grid-2">
            <div><label>Дата явки:</label><input type="date" id="tuDate"></div>
            <div><label>Время явки:</label><input type="time" id="tuTimeYavka"></div>
        </div>
        <div class="grid-2">
            <div><label>Куда (Плечо):</label><input type="text" id="tuDestination" placeholder="Молодечно"></div>
            <div><label>Время сдачи:</label><input type="time" id="tuTimeSdacha"></div>
        </div>
        <button class="btn btn-accent" onclick="calculateAndSaveTrip()">РАССЧИТАТЬ И ВНЕСТИ В ЖУРНАЛ</button>

        <div style="margin-top: 10px;">
            <label>📊 Статистика за месяц:</label>
            <div id="tuStats" style="font-size: 12px; background:#f9fafc; padding: 8px; border-radius: 6px; line-height: 1.5; border: 1px solid #dcdfe6; border-left: 4px solid var(--success-color);">Поездок не обнаружено.</div>
        </div>

        <table class="table-view" id="tripsTable">
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>Плечо</th>
                    <th>Всего</th>
                    <th>Ночные</th>
                    <th>Оплата</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
        <button class="btn" style="background: #f9ecec; color: #e63946; font-size: 11px; padding: 6px; margin-top:8px; border: 1px solid #fcd3d3;" onclick="clearTu3Db()">🗑️ ОЧИСТИТЬ ЖУРНАЛ ТУ-3</button>
    </div>

<script>
const map = L.map('map', { zoomControl: false }).setView([53.9, 27.56], 12);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);

let trainMarker = L.circleMarker([53.9, 27.56], {color: '#e63946', radius: 8, fillColor: '#ffb703', fillOpacity: 0.9}).addTo(map);
let trainPolyline = L.polyline([], {color: '#e63946', weight: 5}).addTo(map);
const canvas = document.getElementById('profileCanvas');
const ctx = canvas.getContext('2d');

let routeNodes = [], terrain = [], objectsDb = [], tu3Db = [];
let trainX = 0, trainCars = 43, trainLength = 602;
let isManualMode = true, isReversed = false, gpsStatus = "Ожидание";
let mapPolyline = null, isMapUserLocked = false;
let startKm = 827, startPk = 8, kmDirection = "up";
let wakeLock = null, watchId = null, audioEnabled = false;

// ===== АУДИО =====
const audioFiles = {
    vstavka: 'audio/vstavka.mp3',
    speed: 'audio/speed.mp3',    signal: 'audio/signal.mp3',
    crossing: 'audio/crossing.mp3'
};

let audioElements = {};

function testAudio() {
    const tel = document.getElementById('telemetry');
    const testFile = 'audio/vstavka.mp3';
    
    tel.innerHTML = '<span style="color:#0077b6">⏳ Проверка: ' + testFile + '</span>';
    
    const audio = new Audio(testFile);
    audio.volume = 0.5;
    
    audio.play().then(() => {
        tel.innerHTML = '<span style="color:#2a9d8f">✔️ Воспроизвожу MP3...</span>';
        setTimeout(() => {
            audio.pause();
            audio.currentTime = 0;
            tel.innerHTML = '<span style="color:#2a9d8f">✅ Звук работает!</span>';
        }, 2000);
    }).catch(err => {
        tel.innerHTML = '<span style="color:#e63946">❌ Ошибка: ' + err.message + '</span>';
    });
}

function activateAudio() {
    if (audioEnabled) {
        document.getElementById('telemetry').innerHTML = '<span style="color:#2a9d8f">✅ Аудио уже включено</span>';
        return;
    }
    
    // Предзагрузка аудио
    Object.keys(audioFiles).forEach(type => {
        const audio = new Audio(audioFiles[type]);
        audio.preload = 'auto';
        audioElements[type] = audio;
    });
    
    // Тест
    const testAudio = new Audio(audioFiles.vstavka);
    testAudio.volume = 0.1;
    testAudio.play().then(() => {
        testAudio.pause();
        audioEnabled = true;
        document.getElementById('audioBadge').className = 'sys-badge badge-ok';
        document.getElementById('audioBadge').textContent = '🔊 Вкл';
        document.getElementById('telemetry').innerHTML = '<span style="color:#2a9d8f">✅ ИНФОРМАТОР АКТИВИРОВАН</span>';
        speak('Информатор активирован');        startGpsWatch();
        requestWakeLock();
    }).catch(err => {
        document.getElementById('telemetry').innerHTML = '<span style="color:#e63946">⚠️ Ошибка аудио: ' + err.message + '</span>';
    });
}

function playAudio(type) {
    if (!audioEnabled) return;
    const audio = audioElements[type];
    if (!audio) return;
    
    audio.currentTime = 0;
    audio.play().catch(err => console.error('Audio error:', err));
}

// ===== GPS =====
function startGpsWatch() {
    if (watchId) navigator.geolocation.clearWatch(watchId);
    
    watchId = navigator.geolocation.watchPosition(
        (pos) => {
            if (isManualMode) return;
            
            const lat = pos.coords.latitude;
            const lon = pos.coords.longitude;
            
            if (routeNodes.length > 0) {
                let minDist = Infinity, bestMeter = 0;
                routeNodes.forEach(node => {
                    const d = getDistance(lat, lon, node.lat, node.lon);
                    if (d < minDist) { minDist = d; bestMeter = node.meterMark; }
                });
                
                trainX = isReversed ? (terrain.length - 1 - bestMeter) : bestMeter;
                updateTrainPosition();
                checkObjects();
            }
            
            const speed = pos.coords.speed ? (pos.coords.speed * 3.6).toFixed(1) : 0;
            gpsStatus = 'GPS: ' + speed + ' км/ч';
            updateTelemetry();
        },
        (err) => { gpsStatus = 'Ошибка GPS'; },
        { enableHighAccuracy: true, maximumAge: 0, timeout: 5000 }
    );
}

function checkObjects() {
    objectsDb.forEach(obj => {        const cb = document.getElementById('voice_' + obj.type);
        if (!cb || !cb.checked) return;
        
        const dist = obj.meterMark - trainX;
        if (dist >= 450 && dist <= 550 && !obj.spoken) {
            playAudio(obj.type);
            speak('Внимание, через 500 метров ' + obj.name);
            obj.spoken = true;
        }
        if (Math.abs(dist) > 700) obj.spoken = false;
    });
}

function getDistance(lat1, lon1, lat2, lon2) {
    const R = 6371000;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLon = (lon2 - lon1) * Math.PI / 180;
    const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180) * Math.cos(lat2*Math.PI/180) * Math.sin(dLon/2)**2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

// ===== ФАЙЛЫ =====
function loadRouteFile(input) {
    const file = input.files[0];
    if (!file) return;
    
    document.getElementById('file-info').innerHTML = '<span style="color:#0077b6">⏳ Чтение: ' + file.name + '</span>';
    
    const reader = new FileReader();
    reader.onload = function(e) {
        try {
            const text = e.target.result;
            let pts = [];
            
            if (text.includes('<gpx') || text.includes('<trkpt')) {
                const parser = new DOMParser();
                const xml = parser.parseFromString(text, 'text/xml');
                const err = xml.querySelector('parsererror');
                if (err) throw new Error('Неверный GPX');
                
                const trkpts = xml.getElementsByTagName('trkpt');
                for (let i = 0; i < trkpts.length; i++) {
                    const lat = parseFloat(trkpts[i].getAttribute('lat'));
                    const lon = parseFloat(trkpts[i].getAttribute('lon'));
                    const ele = trkpts[i].getElementsByTagName('ele')[0];
                    if (!isNaN(lat) && !isNaN(lon)) {
                        pts.push({ lat, lon, h: ele ? parseFloat(ele.textContent) : 150 });
                    }
                }
            } else if (text.trim().startsWith('{')) {                const json = JSON.parse(text);
                function extract(c) {
                    if (!c) return;
                    if (typeof c[0] === 'number' && c.length >= 2) {
                        pts.push({ lat: c[1], lon: c[0], h: c[2] || 150 });
                    } else if (Array.isArray(c[0])) {
                        c.forEach(extract);
                    }
                }
                if (json.type === 'FeatureCollection') {
                    json.features.forEach(f => { if (f.geometry) extract(f.geometry.coordinates); });
                } else if (json.geometry) {
                    extract(json.geometry.coordinates);
                }
            } else {
                throw new Error('Неподдерживаемый формат');
            }
            
            if (pts.length < 2) throw new Error('Нет точек маршрута');
            
            // Process
            routeNodes = []; terrain = []; let totalM = 0;
            for (let i = 0; i < pts.length; i++) {
                if (i > 0) totalM += getDistance(pts[i-1].lat, pts[i-1].lon, pts[i].lat, pts[i].lon);
                routeNodes.push({ lat: pts[i].lat, lon: pts[i].lon, height: pts[i].h, meterMark: totalM });
            }
            
            let idx = 0;
            for (let m = 0; m <= totalM; m++) {
                while (idx < routeNodes.length - 1 && routeNodes[idx+1].meterMark < m) idx++;
                const p1 = routeNodes[idx], p2 = routeNodes[idx+1] || p1;
                terrain.push(p2.meterMark !== p1.meterMark ? p1.height + (m - p1.meterMark)/(p2.meterMark - p1.meterMark) * (p2.height - p1.height) : p1.height);
            }
            
            if (mapPolyline) map.removeLayer(mapPolyline);
            mapPolyline = L.polyline(routeNodes.map(n => [n.lat, n.lon]), {color: '#0077b6', weight: 4}).addTo(map);
            map.fitBounds(mapPolyline.getBounds());
            
            document.getElementById('manualMeterSlider').max = Math.round(totalM);
            document.getElementById('file-info').innerHTML = '<span style="color:#2a9d8f">✔️ ' + (totalM/1000).toFixed(2) + ' км</span>';
            
            setManualMetrage(0);
            recalculateObjectsMeterMarks();
            recreateMapMarkers();
            renderTraTable();
            
        } catch (err) {
            document.getElementById('file-info').innerHTML = '<span style="color:#e63946">❌ ' + err.message + '</span>';
        }
    };    reader.readAsText(file);
}

// ===== ОТРИСОВКА =====
function updateTrainPosition() {
    if (routeNodes.length === 0) return;
    const maxM = terrain.length - 1;
    const headM = isReversed ? (maxM - trainX) : trainX;
    const idx = Math.min(routeNodes.length - 1, Math.floor((headM / maxM) * routeNodes.length));
    const pos = [routeNodes[idx].lat, routeNodes[idx].lon];
    
    trainMarker.setLatLng(pos);
    if (!isMapUserLocked) map.panTo(pos, { animate: true });
    document.getElementById('manualMeterInput').value = Math.round(trainX);
    document.getElementById('manualMeterSlider').value = Math.round(trainX);
}

function drawProfile() {
    if (terrain.length === 0) {
        ctx.fillStyle = '#666'; ctx.font = '12px sans-serif';
        ctx.fillText('Загрузите маршрут', 200, 70);
        requestAnimationFrame(drawProfile);
        return;
    }
    
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const viewM = 3000, scale = viewM / canvas.width, offset = trainX - viewM/2;
    const maxM = terrain.length - 1;
    
    let minH = Infinity, maxH = -Infinity;
    for (let x = 0; x < canvas.width; x++) {
        const m = Math.floor(offset + x * scale);
        if (m >= 0 && m < terrain.length) {
            const h = terrain[m];
            if (h < minH) minH = h;
            if (h > maxH) maxH = h;
        }
    }
    if (maxH - minH < 20) { minH -= 10; maxH += 10; }
    const hRange = maxH - minH;
    
    const getY = (m) => m < 0 || m >= terrain.length ? canvas.height - 20 : canvas.height - ((terrain[m] - minH) / hRange) * (canvas.height - 40) - 20;
    
    ctx.strokeStyle = '#e1e4e8'; ctx.lineWidth = 1; ctx.beginPath();
    for (let x = 0; x < canvas.width; x += 50) { ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); }
    ctx.stroke();
    
    ctx.strokeStyle = '#0077b6'; ctx.lineWidth = 3; ctx.beginPath();
    for (let x = 0; x < canvas.width; x++) {
        const m = Math.floor(offset + x * scale);        if (x === 0) ctx.moveTo(x, getY(m)); else ctx.lineTo(x, getY(m));
    }
    ctx.stroke();
    
    ctx.fillStyle = isManualMode ? '#ff9f1c' : '#e63946';
    ctx.beginPath(); ctx.arc(canvas.width/2, getY(trainX), 6, 0, Math.PI*2); ctx.fill();
    
    requestAnimationFrame(drawProfile);
}

// ===== УТИЛИТЫ =====
function speak(text) {
    if ('speechSynthesis' in window) {
        window.speechSynthesis.cancel();
        const u = new SpeechSynthesisUtterance(text);
        u.lang = 'ru-RU'; u.rate = 0.95;
        window.speechSynthesis.speak(u);
    }
}

async function requestWakeLock() {
    try {
        if ('wakeLock' in navigator) {
            await navigator.wakeLock.request('screen');
            document.getElementById('wakeLockBadge').className = 'sys-badge badge-ok';
            document.getElementById('wakeLockBadge').textContent = '🔋 No Sleep';
        }
    } catch (e) {}
}

function updateTelemetry() {
    const km = Math.floor(trainX / 1000);
    const pk = Math.floor((trainX % 1000) / 100) + 1;
    document.getElementById('telemetry').innerHTML = 
        '🛰️ <b>' + gpsStatus + '</b><br>' +
        '📍 <b>' + km + ' км ' + pk + ' пк</b><br>' +
        '🚃 ' + trainCars + ' ваг. | 📋 ' + objectsDb.length + ' объектов';
}

// ===== ОБЪЕКТЫ =====
function addCustomTraObject() {
    const name = document.getElementById('manualObjName').value.trim();
    const km = parseInt(document.getElementById('manualObjKm').value);
    const pk = parseInt(document.getElementById('manualObjPk').value);
    const type = document.getElementById('manualObjType').value;
    
    if (!name || routeNodes.length === 0) { alert('Заполните поля и загрузите маршрут'); return; }
    
    const meterMark = (km * 1000) + ((pk - 1) * 100);
    const idx = Math.min(routeNodes.length - 1, Math.floor((meterMark / (terrain.length || 1)) * routeNodes.length));    const node = routeNodes[idx] || routeNodes[0];
    const colors = { vstavka: '#ffb703', speed: '#e63946', signal: '#0077b6', crossing: '#f4a261' };
    
    objectsDb.push({ name, type, meterMark, lat: node.lat, lon: node.lon, color: colors[type], spoken: false });
    localStorage.setItem('bch_tra_db', JSON.stringify(objectsDb));
    renderTraTable();
    document.getElementById('manualObjName').value = '';
}

function fixObjectInCurrentPoint(type, name) {
    if (routeNodes.length === 0) { alert('Загрузите маршрут'); return; }
    const maxM = terrain.length - 1;
    const meterMark = isReversed ? (maxM - trainX) : trainX;
    const idx = Math.min(routeNodes.length - 1, Math.floor((meterMark / maxM) * routeNodes.length));
    const node = routeNodes[idx];
    const colors = { vstavka: '#ffb703', speed: '#e63946', signal: '#0077b6', crossing: '#f4a261' };
    
    objectsDb.push({ name, type, meterMark, lat: node.lat, lon: node.lon, color: colors[type], spoken: false });
    localStorage.setItem('bch_tra_db', JSON.stringify(objectsDb));
    renderTraTable();
    speak('Зафиксировано: ' + name);
}

function renderTraTable() {
    const tbody = document.querySelector('#objectsTraTable tbody');
    tbody.innerHTML = '';
    objectsDb.sort((a,b) => a.meterMark - b.meterMark).forEach((obj, i) => {
        const km = Math.floor(obj.meterMark / 1000);
        const pk = Math.floor((obj.meterMark % 1000) / 100) + 1;
        tbody.innerHTML += '<tr><td style="color:' + obj.color + '">' + obj.name + '</td><td>' + km + ' км ' + pk + ' пк</td><td>' + Math.round(obj.meterMark) + ' м</td><td><button class="btn btn-danger" style="padding:4px;margin:0;font-size:10px;" onclick="removeObject(' + i + ')">✕</button></td></tr>';
    });
}

function removeObject(i) {
    objectsDb.splice(i, 1);
    localStorage.setItem('bch_tra_db', JSON.stringify(objectsDb));
    renderTraTable();
}

function recreateMapMarkers() {
    map.eachLayer(layer => { if (layer instanceof L.CircleMarker && layer !== trainMarker) map.removeLayer(layer); });
    objectsDb.forEach(obj => {
        L.circleMarker([obj.lat, obj.lon], {color: obj.color, radius: 5, fillColor: obj.color}).addTo(map).bindPopup(obj.name);
    });
}

function recalculateObjectsMeterMarks() {}

function clearObjectsDb() {
    if (confirm('Очистить базу?')) {        objectsDb = []; localStorage.removeItem('bch_tra_db');
        recreateMapMarkers(); renderTraTable();
    }
}

// ===== ТУ-3 =====
function calculateAndSaveTrip() {
    const date = document.getElementById('tuDate').value;
    const yavka = document.getElementById('tuTimeYavka').value;
    const sdacha = document.getElementById('tuTimeSdacha').value;
    const dest = document.getElementById('tuDestination').value || '';
    
    if (!date || !yavka || !sdacha) return;
    
    const t1 = new Date(date + 'T' + yavka);
    const t2 = new Date(date + 'T' + sdacha);
    if (t2 < t1) t2.setDate(t2.getDate() + 1);
    
    const totalMin = (t2 - t1) / 60000;
    let nightMin = 0, t = new Date(t1);
    while (t < t2) { if (t.getHours() >= 22 || t.getHours() < 6) nightMin++; t.setMinutes(t.getMinutes() + 1); }
    
    const totalH = totalMin / 60, nightH = nightMin / 60;
    const rate = nightMin / totalMin >= 0.5 ? '40%' : '35%';
    
    tu3Db.push({ date, dest, total: totalH, night: nightH, rate });
    localStorage.setItem('bch_tu3_db', JSON.stringify(tu3Db));
    renderTu3Table();
}

function renderTu3Table() {
    const tbody = document.querySelector('#tripsTable tbody');
    tbody.innerHTML = '';
    let sumTotal = 0, sumNight = 0;
    tu3Db.forEach(t => {
        tbody.innerHTML += '<tr><td>' + t.date + '</td><td>' + t.dest + '</td><td>' + t.total.toFixed(2) + '</td><td>' + t.night.toFixed(2) + '</td><td>' + t.rate + '</td></tr>';
        sumTotal += t.total; sumNight += t.night;
    });
    document.getElementById('tuStats').innerHTML = 'Поездок: <b>' + tu3Db.length + '</b> | Всего: <b>' + sumTotal.toFixed(2) + ' ч</b>';
}

function clearTu3Db() {
    if (confirm('Очистить журнал?')) {
        tu3Db = []; localStorage.removeItem('bch_tu3_db');
        renderTu3Table();
    }
}

// ===== НАСТРОЙКИ =====
function updateKilometerSettings() {    startKm = parseInt(document.getElementById('startKmInput').value) || 0;
    startPk = parseInt(document.getElementById('startPkInput').value) || 1;
    kmDirection = document.getElementById('kmDirectionSelect').value;
    localStorage.setItem('bch_km_start', startKm);
    localStorage.setItem('bch_pk_start', startPk);
    localStorage.setItem('bch_km_dir', kmDirection);
}

function toggleReverse() {
    isReversed = !isReversed;
    trainX = (terrain.length - 1) - trainX;
    if (trainX < 0) trainX = 0;
    document.getElementById('manualMeterSlider').value = Math.round(trainX);
    document.getElementById('manualMeterInput').value = Math.round(trainX);
    updateTrainPosition();
    speak('Реверс');
}

function updateTrainLength(val) {
    trainCars = parseInt(val) || 1;
    trainLength = trainCars * 14;
    document.getElementById('trainCarsInput').value = trainCars;
    document.getElementById('trainCarsSlider').value = trainCars;
    document.getElementById('calculatedLengthText').textContent = 'Расчетная длина: ' + trainLength + ' м';
}

function centerMapOnTrainHead() {
    if (routeNodes.length === 0) return;
    const maxM = terrain.length - 1;
    const headM = isReversed ? (maxM - trainX) : trainX;
    const idx = Math.min(routeNodes.length - 1, Math.floor((headM / maxM) * routeNodes.length));
    map.panTo([routeNodes[idx].lat, routeNodes[idx].lon], { animate: true });
}

function setManualMetrage(val) {
    const m = parseFloat(val) || 0;
    if (routeNodes.length === 0) return;
    trainX = Math.max(0, Math.min(m, terrain.length - 1));
    document.getElementById('manualMeterInput').value = Math.round(trainX);
    document.getElementById('manualMeterSlider').value = Math.round(trainX);
    updateTrainPosition();
}

function handleManualScroll(val) { isMapUserLocked = true; setManualMetrage(val); }

// ===== СОБЫТИЯ =====
document.getElementById('manualMeterInput').addEventListener('input', e => setManualMetrage(e.target.value));
document.getElementById('manualMeterSlider').addEventListener('input', e => {
    document.getElementById('manualMeterInput').value = e.target.value;
    setManualMetrage(e.target.value);});
document.getElementById('trainCarsInput').addEventListener('input', e => updateTrainLength(e.target.value));
document.getElementById('trainCarsSlider').addEventListener('input', e => {
    document.getElementById('trainCarsInput').value = e.target.value;
    updateTrainLength(e.target.value);
});

map.on('dragstart zoomstart', () => {
    isMapUserLocked = true;
    setTimeout(() => { isMapUserLocked = false; }, 5000);
});

// ===== ИНИЦИАЛИЗАЦИЯ =====
window.onload = function() {
    if (localStorage.getItem('bch_km_start')) {
        startKm = parseInt(localStorage.getItem('bch_km_start'));
        startPk = parseInt(localStorage.getItem('bch_pk_start'));
        kmDirection = localStorage.getItem('bch_km_dir') || 'up';
        document.getElementById('startKmInput').value = startKm;
        document.getElementById('startPkInput').value = startPk;
        document.getElementById('kmDirectionSelect').value = kmDirection;
    }
    
    if (localStorage.getItem('bch_tra_db')) {
        try { objectsDb = JSON.parse(localStorage.getItem('bch_tra_db')); renderTraTable(); recreateMapMarkers(); } catch(e) {}
    }
    if (localStorage.getItem('bch_tu3_db')) {
        try { tu3Db = JSON.parse(localStorage.getItem('bch_tu3_db')); renderTu3Table(); } catch(e) {}
    }
    
    document.getElementById('tuDate').value = new Date().toISOString().split('T')[0];
    if ('speechSynthesis' in window) window.speechSynthesis.speak(new SpeechSynthesisUtterance(''));
    
    drawProfile();
};
</script>

