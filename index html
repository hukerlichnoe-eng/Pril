<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Бортовой Помощник БЧ v15.8</title>
    <style>
        .leaflet-container{overflow:hidden;width:100%;height:100%;position:relative;background:#efede4;font:12px/1.5 "Helvetica Neue",Arial,Helvetica,sans-serif}
        .leaflet-pane,.leaflet-tile-layer{position:absolute;left:0;top:0}
        .leaflet-pane{z-index:400}
        .leaflet-tile{position:absolute;pointer-events:none}
        
        :root {
            --bg-color: #f4f5f7;
            --card-bg: #ffffff;
            --accent-color: #0077b6;
            --text-color: #1d2129;
            --success-color: #2a9d8f;
            --danger-color: #e63946;
            --warning-color: #ff9f1c;
            --orange-color: #f4a261;
        }
        body { 
            margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: var(--bg-color); color: var(--text-color); padding: 10px; box-sizing: border-box;
        }
        .card { 
            background: var(--card-bg); padding: 12px; border-radius: 8px; margin-bottom: 12px; box-shadow: 0 2px 6px rgba(0,0,0,0.1); border: 1px solid #dcdfe6;
        }
        h3 { margin-top: 0; color: var(--accent-color); border-bottom: 1px solid #dcdfe6; padding-bottom: 4px; font-size: 15px; text-transform: uppercase; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
        .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; }
        label { font-size: 11px; display: block; margin-bottom: 3px; color: #606266; font-weight: bold; }
        input, select { width: 100%; padding: 8px; background: #ffffff; border: 1px solid #dcdfe6; color: var(--text-color); border-radius: 6px; box-sizing: border-box; margin-bottom: 6px; font-size: 13px; }
        .btn { display: block; width: 100%; padding: 12px; border: none; color: white; font-weight: bold; border-radius: 6px; cursor: pointer; text-align: center; box-sizing: border-box; font-size: 13px; text-transform: uppercase; margin-top: 6px; }
        .btn:active { transform: scale(0.98); }
        .btn-accent { background: var(--accent-color); color: #fff; }
        .btn-danger { background: var(--danger-color); color: #fff; }
        .btn-warn { background: var(--warning-color); color: #fff; }
        .btn-orange { background: var(--orange-color); color: #fff; }
        .btn-success { background: var(--success-color); color: #fff; }
        #map { height: 260px; width: 100%; border-radius: 6px; border: 1px solid #dcdfe6; margin-bottom: 8px; }
        canvas { background-color: #fdfdfd; border: 1px solid #dcdfe6; border-radius: 6px; width: 100%; display: block; margin-bottom: 8px; }
        .status-box { font-size: 12px; line-height: 1.5; background: #fdfdfd; padding: 10px; border-radius: 6px; border: 1px solid #dcdfe6; border-left: 4px solid var(--accent-color); }
        .cb-group { background: #f9fafc; padding: 8px; border-radius: 6px; margin-bottom: 8px; border: 1px solid #dcdfe6; }
        .cb-item { display: flex; align-items: center; margin-bottom: 4px; font-size: 12px; }
        .cb-item input { width: auto; margin-right: 8px; margin-bottom: 0; }
        .table-view { width: 100%; border-collapse: collapse; font-size: 11px; margin-top: 6px; }
        .table-view th, .table-view td { border: 1px solid #dcdfe6; padding: 6px; text-align: left; }
        .table-view th { background: #f5f7fa; color: var(--accent-color); }
        .sys-badge { display: inline-block; font-size: 10px; padding: 2px 6px; border-radius: 4px; font-weight: bold; margin-right: 4px; }        .badge-ok { background: #2a9d8f; color: #fff; }
        .badge-err { background: #e63946; color: #fff; }
    </style>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>

    <div class="card" style="background: var(--card-bg); border-left: 4px solid var(--warning-color);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size:12px; font-weight:bold;">🛠️ Фоновые службы:</span>
            <div>
                <span id="wakeLockBadge" class="sys-badge badge-err">Экран: Сон</span>
                <span id="audioBadge" class="sys-badge badge-err">🔇 Аудио</span>
            </div>
