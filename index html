    <div class="card">
        <h3>🗺️ Навигация и Профиль пути (v15.8)</h3>
        <div id="map"></div>
        
        <button class="btn btn-accent" style="margin-bottom: 10px; padding: 12px; font-size: 13px;" onclick="centerMapOnTrainHead()">🎯 Вернуться к голове</button>
        
        <div style="background: #f9fafc; padding: 8px; border-radius: 6px; border: 1px dashed var(--accent-color); margin-bottom: 8px;">
            <label style="color: var(--accent-color);">🕒 Прокрутка координат / Коррекция наката:</label>
            <div class="grid-2">
                <input type="number" id="manualMeterInput" value="0" oninput="handleManualScroll(this.value)">
