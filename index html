    <div class="card">
        <h3>📂 Загрузка ЖД Маршрута</h3>
        <button class="btn btn-accent" onclick="document.getElementById('fileInput').click()">
            📂 ОТКРЫТЬ .GPX ИЛИ .GEOJSON
        </button>
        <input type="file" id="fileInput" accept=".gpx,.geojson,.json" style="display:none;" onchange="loadRouteFile(this)">
        <div id="file-info" style="margin-top: 8px; font-size:12px; color:#606266; text-align:center;"></div>
